# Copie para .env e ajuste os valores. NUNCA versione o .env real.

# ---- Django ----
DJANGO_SECRET_KEY=troque-por-uma-string-longa-e-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev
# Chave Fernet (base64 urlsafe, 32 bytes) p/ cifrar campos clínicos sensíveis.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Em dev pode deixar vazio (deriva da SECRET_KEY). Em produção, DEFINA SEMPRE.
FIELD_ENCRYPTION_KEY=

# ---- MySQL ----
MYSQL_DATABASE=amanda
MYSQL_USER=amanda
MYSQL_PASSWORD=amanda_pass
MYSQL_ROOT_PASSWORD=root_pass
DB_HOST=db
DB_PORT=3306

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Frontend / CORS ----
FRONTEND_URL=http://localhost:3000

# ---- JWT ----
ACCESS_TOKEN_LIFETIME_MIN=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- Integrações (preencher nas fases correspondentes) ----
DAILY_API_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ---- Next.js ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api
